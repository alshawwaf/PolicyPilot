# Copy to .env and fill in. All vars are prefixed PILOT_.

# Public URL of the portal — used to build the feed URLs shown to the SE.
# Behind Caddy this is your HTTPS domain.
PILOT_BASE_URL=https://policypilot.example.com

# Domain Caddy obtains a Let's Encrypt certificate for (docker-compose only).
PILOT_DOMAIN=policypilot.example.com

# REQUIRED in production: cookie-signing key for portal sessions.
# Generate one with:  openssl rand -base64 32
PILOT_SESSION_SECRET=

# Dedicated at-rest encryption key (AES-256-GCM) for saved gateway/datacenter/management
# credentials and portal-set integration secrets (MCP token, webhook, ServiceNow).
# Recommended in production. Generate with:  openssl rand -base64 32
# If unset it falls back to PILOT_SESSION_SECRET — but then rotating the session secret makes
# stored credentials unreadable, so set a dedicated key to keep them independent.
PILOT_ENCRYPTION_KEY=

# Portal admin login. If the password is left blank, a random one is generated
# and printed to the logs once at first startup.
PILOT_ADMIN_USERNAME=admin
PILOT_ADMIN_PASSWORD=

# SQLite location (default is fine; the container uses /data via a volume).
# PILOT_DATABASE_URL=sqlite:///./data/policypilot.db
