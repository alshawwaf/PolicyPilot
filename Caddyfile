# Caddy terminates TLS (automatic Let's Encrypt for a real domain) and proxies
# to the app. This is what removes the cert-trust friction during a PoV:
# the gateway sees a publicly-trusted HTTPS endpoint.
#
# For a local/lab demo set PILOT_DOMAIN=localhost — Caddy issues an internal cert.

{$PILOT_DOMAIN} {
	encode gzip
	reverse_proxy app:8000
}
